{
  "name": "qa-automation-sandbox",
  "version": "1.0.0",
  "description": "**A free, open-source, full-stack social network designed specifically as a practice environment for QA automation engineers.**",
  "main": "index.js",
  "scripts": {
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:smoke": "playwright test e2e/smoke.spec.ts --project=chromium",
    "test:gherkin": "cucumber-js --config=cucumber.js",
    "test:pbt": "jest --config=jest.config.ts",
    "test:db": "jest --config=jest.config.ts --testPathPattern=db",
    "test:components": "jest --config=jest.config.ts --testPathPattern=components",
    "test:python": "pytest python/tests/ -v",
    "test:go": "go test -v ./go/...",
    "test:k6": "k6 run k6/api-load-test.js",
    "test:k6:quick": "k6 run -e QUICK=true k6/api-load-test.js",
    "test:load:smoke": "playwright test e2e/load/smoke-load.spec.ts --project=chromium",
    "test:load:basic": "playwright test e2e/load/basic-load.spec.ts --project=chromium",
    "test:load:stress": "playwright test e2e/load/stress-load.spec.ts --project=chromium",
    "test:load:network": "playwright test e2e/load/network-fail.spec.ts --project=chromium",
    "test:load:all": "playwright test e2e/load/",
    "lint": "eslint e2e/ pbt/ db/ --max-warnings=0",
    "typecheck": "tsc --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/manikosto/qa-automation-sandbox.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/manikosto/qa-automation-sandbox/issues"
  },
  "homepage": "https://github.com/manikosto/qa-automation-sandbox#readme",
  "devDependencies": {
    "@cucumber/cucumber": "^12.8.1",
    "@fast-check/jest": "^2.2.0",
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^30.0.0",
    "@types/pg": "^8.20.0",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.57.0",
    "fast-check": "^4.6.0",
    "jest": "^30.3.0",
    "pg": "^8.20.0",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2"
  }
}
